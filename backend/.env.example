DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kerala_ayurvedh"
# Use DIRECT_URL for Prisma CLI commands such as migrations.
# For Supabase, set DATABASE_URL to the transaction pooler URL and DIRECT_URL to
# the session pooler/direct URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/kerala_ayurvedh"
JWT_SECRET="change-this-secret-before-production"
PORT=4000
CORS_ORIGIN=""
# Comma-separated production allowlist example:
# CORS_ORIGIN="https://keralaayurvedh.com,https://www.keralaayurvedh.com"
JSON_BODY_LIMIT="1mb"
DATABASE_STORAGE_LIMIT_MB=""
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="Kerala Ayurvedh"
SUPPORT_EMAIL=""
BACKUP_DIR="backups"
BACKUP_MAX_AGE_HOURS=30
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="public"
LOCAL_PRIVATE_UPLOAD_DIR="private-uploads"
# For PaaS persistent volumes, use absolute mounted paths, e.g.
# LOCAL_UPLOAD_DIR="/data/public"
# LOCAL_PRIVATE_UPLOAD_DIR="/data/private-uploads"
R2_BUCKET=""
R2_REGION="auto"
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BASE_URL=""
R2_FORCE_PATH_STYLE=false
STORAGE_SIGNED_URL_EXPIRES_SECONDS=300
